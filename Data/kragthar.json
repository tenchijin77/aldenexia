  "factions": {
    "bonegnawer_gnolls": {
      "alignment": "hostile",
      "description": "Gnolls who claimed the ancient halfling barrow as their den.",
      "notes": "Social aggro; will assist nearby gnolls."
    },
    "undead": {
      "alignment": "hostile",
      "description": "Ancient halfling nobles and guardians awakened by Void rituals.",
      "notes": "Spawn from sarcophagi and crypt chambers."
    },
    "moribund_order": {
      "alignment": "hostile",
      "description": "Void cultists attempting to harness the tomb’s necromantic secrets.",
      "notes": "Kael’vros the Awakener leads their efforts."
    }
  },

  "wings": [
    {
      "wing_name": "Entrance Chamber",
