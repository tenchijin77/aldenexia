  "atmosphere": "A sprawling, chaotic, multi-wing dungeon where Bonegnawer gnolls, awakened undead, and Moribund agents battle for control. Fast respawns, contested camps, and dangerous traps define the experience.",

  "signature_hazards": [
    "cave_in_traps",
    "poison_dart_traps",
    "acid_spout_traps",
    "cursed_sarcophagi",
    "patrol_timing_challenges",
    "line_of_sight_pulling"
